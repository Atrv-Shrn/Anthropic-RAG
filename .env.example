# ---- GitHub corpus (public repo read access) ----
GITHUB_TOKEN=
GITHUB_ORG=anthropics

# ---- Local Ollama embeddings (dense, nomic) ----
# Host ports are remapped in docker-compose.yml (11144) so this stack does not
# clash with other local qdrant/redis/ollama instances on the standard ports.
OLLAMA_EMBED_BASE_URL=http://localhost:11144
EMBED_MODEL=nomic-embed-text

# ---- Ollama Cloud: generation + RAGAS judge ----
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_API_KEY=
GEN_MODEL=deepseek-v4-pro:cloud

# ---- Stores ----
# Host ports remapped (16333 / 16379) — see docker-compose.yml.
QDRANT_URL=http://localhost:16333
QDRANT_COLLECTION=anthropic_rag
REDIS_URL=redis://localhost:16379

# ---- MCP server ----
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Set a bearer token when exposing beyond localhost (e.g. on EC2).
MCP_AUTH_TOKEN=
